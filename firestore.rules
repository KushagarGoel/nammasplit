rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Allow read if authenticated (users can see other users like friends)
      allow read: if isAuthenticated();
      // Allow create if authenticated and creating own profile or demo friend
      allow create: if isAuthenticated() && (
        request.auth.uid == userId ||
        (request.resource.data.isDemo == true && request.resource.data.name is string)
      );
      // Allow update if owner
      allow update: if isOwner(userId);
    }

    // Friends subcollection: users/{uid}/friends/{friendId}
    match /users/{userId}/friends/{friendId} {
      // Allow read if owner, or if the friend being read is the current user
      allow read: if isOwner(userId);
      // Allow write if owner, or if adding yourself as a friend (for invitation acceptance)
      allow write: if isOwner(userId) || request.auth.uid == friendId;
    }

    // Groups collection
    match /groups/{groupId} {
      // Allow read if user is a member
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      // Allow create if user is authenticated and is the creator
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.members
        && request.auth.uid == request.resource.data.createdBy;
      // Allow update if user is a member
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members
        && request.auth.uid in request.resource.data.members;
      // Allow delete only by creator
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    // Expenses collection
    match /expenses/{expenseId} {
      // Allow read if user is involved in the expense
      allow read: if isAuthenticated() && request.auth.uid in resource.data.involvedUsers;
      // Allow create if user is authenticated and is part of the expense
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.involvedUsers
        && request.auth.uid == request.resource.data.paidBy;
      // Allow update if user is involved
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.involvedUsers
        && request.auth.uid in request.resource.data.involvedUsers;
      // Allow delete if user is involved in the expense
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.involvedUsers;
    }

    // Settlements collection
    match /settlements/{settlementId} {
      // Allow read if user is sender or receiver
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      // Allow create if user is either sender or receiver
      allow create: if isAuthenticated()
        && (request.auth.uid == request.resource.data.fromUserId || request.auth.uid == request.resource.data.toUserId);
      // Allow update/delete if user is sender or receiver
      allow update, delete: if isAuthenticated()
        && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
    }

    // Activities collection
    match /activities/{activityId} {
      // Allow read if user is involved
      allow read: if isAuthenticated() && request.auth.uid in resource.data.involvedUsers;
      // Allow create if user creates activity involving themselves
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.involvedUsers
        && request.auth.uid == request.resource.data.userId;
      // Allow update/delete if user created it
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Invitations collection - for pending friend invites
    match /invitations/{invitationId} {
      // Allow create if authenticated user is the inviter
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.fromUserId
        && request.resource.data.toEmail is string
        && request.resource.data.friendName is string;
      // Allow read if user owns the invitation (by fromUserId) or if checking by email
      // Note: In production, you might want to restrict email-based reads to Cloud Functions
      allow read: if isAuthenticated();
      // Allow delete if user is the inviter or the invitee (by email match)
      allow delete: if isAuthenticated()
        && (request.auth.uid == resource.data.fromUserId || request.auth.token.email == resource.data.toEmail);
    }
  }
}
